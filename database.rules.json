{
  "rules": {
    "rooms": {
      "$roomCode": {
        ".read": true,
        ".write": true,
        "members": {
          "$uid": {
            ".write": true
          }
        },
        "messages": {
          ".write": true,
          ".indexOn": ["timestamp"]
        },
        "playback": {
          ".write": true
        },
        "streamUrl": {
          ".write": true
        },
        "embedUrl": {
          ".write": true
        },
        "watchMode": {
          ".write": true
        },
        "streamQueue": {
          ".write": true
        }
      }
    }
  }
}
